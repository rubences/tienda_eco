{
  "name": "tienda_eco",
  "version": "1.0.0",
  "description": "Arquitectura monolitica: cliente + API Express + SQLite + Nginx",
  "main": "src/server.js",
  "scripts": {
    "start:api": "node src/server.js",
    "start:hola": "node hola_mundo.js",
    "start:pedido": "node pedido.js",
    "https:enable": "bash scripts/enable-https-letsencrypt.sh",
    "https:renew": "bash scripts/renew-https-letsencrypt.sh",
    "https:selfsigned": "bash scripts/enable-https-selfsigned.sh",
    "bench:ab": "bash scripts/ab-benchmark.sh",
    "bench:loadtest": "loadtest -n 500 -c 50 http://localhost:8080/api/health",
    "verify:redirects": "bash scripts/verify-redirects.sh",
    "monitor:start": "bash scripts/start-monitoring.sh",
    "monitor:compose": "docker compose ps",
    "monitor:compose:all": "docker compose -f docker-compose.yml -f docker-compose.monitoring.yml ps",
    "monitor:ports": "netstat -tulpen | grep -E ':80|:443|:8080|:3000|:19999|:9090|:3001' || true",
    "monitor:top": "htop",
    "test": "echo \"Sin tests automatizados\" && exit 0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rubences/tienda_eco.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/rubences/tienda_eco/issues"
  },
  "homepage": "https://github.com/rubences/tienda_eco#readme",
  "dependencies": {
    "dayjs": "^1.11.19",
    "express": "^5.2.1",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "loadtest": "^8.2.1"
  }
}
