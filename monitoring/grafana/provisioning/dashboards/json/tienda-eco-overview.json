{
  "id": null,
  "uid": "tienda-eco-overview",
  "title": "Tienda Eco Overview",
  "tags": ["tienda-eco", "nginx", "prometheus"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Nginx Active Connections",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "refId": "A", "expr": "nginx_connections_active" }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto"
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Nginx Requests/s",
      "gridPos": { "h": 8, "w": 12, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "refId": "A", "expr": "rate(nginx_http_requests_total[1m])", "legendFormat": "requests/s" }]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Nginx Connection States",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "nginx_connections_reading", "legendFormat": "reading" },
        { "refId": "B", "expr": "nginx_connections_writing", "legendFormat": "writing" },
        { "refId": "C", "expr": "nginx_connections_waiting", "legendFormat": "waiting" }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Nginx Accepted Connections/s",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "refId": "A", "expr": "rate(nginx_connections_accepted[1m])" }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto"
      }
    }
  ],
  "templating": { "list": [] },
  "time": { "from": "now-15m", "to": "now" },
  "timepicker": {},
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  }
}
